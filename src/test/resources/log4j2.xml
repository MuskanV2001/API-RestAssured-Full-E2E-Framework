<?xml version="1.0" encoding="UTF-8" ?>
<Configuration status = "WARN">
    <Appenders>
        <Console name = "Console Appender" target = "SYSTEM_OUT">
            <PatternLayout pattern="%d{HH:mm:ss} [%t] %-10level %logger{36} -- %msg%n">
            </PatternLayout>
        </Console>
        <File name = "File Appender" fileName = "logs/test.log">
            <PatternLayout pattern="%d{HH:mm:ss} [%t] %-10level %logger{36} -- %msg%n">
            </PatternLayout>
        </File>
    </Appenders>

    <Loggers>
        <Root level = "info">
            <AppenderRef ref = "Console Appender"/>
            <AppenderRef ref = "File Appender"/>
        </Root>
    </Loggers>
</Configuration>